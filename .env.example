HH_ANTHROPIC_API_KEY=sk-ant-api03-...
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Applicant thank-you email — sent on submission via ImprovMX SMTP.
# The admin dashboard (HackerHouse repo) runs a cron backstop, so missing
# values here only mean applicants don't get the instant email; the cron
# will pick them up within ~15 min.
SMTP_HOST=smtp.improvmx.com
SMTP_PORT=587
SMTP_USER=summerschool@aifoundations.school
SMTP_PASS=change-me
SMTP_FROM="AI Foundations <summerschool@aifoundations.school>"
