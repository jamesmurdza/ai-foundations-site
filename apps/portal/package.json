{
  "name": "ssportal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "node --env-file=.env.local --import tsx src/scripts/seed.ts",
    "clean": "node --env-file=.env.local --import tsx src/scripts/clean.ts",
    "backfill:usernames": "node --env-file=.env.local --import tsx src/scripts/backfill-usernames.ts",
    "dedupe:submissions": "node --env-file=.env.local --import tsx src/scripts/dedupe-submissions.ts",
    "backfill:repo-owners": "node --env-file=.env.local --import tsx src/scripts/backfill-repo-owners.ts",
    "seed:tinysend": "node --env-file=.env.local --import tsx src/scripts/seed-tinysend-ledger.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@vercel/blob": "^2.4.0",
    "d3-geo": "^3.1.1",
    "drizzle-orm": "^0.45.2",
    "github-markdown-css": "^5.9.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.4",
    "topojson-client": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@types/topojson-client": "^3.1.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
