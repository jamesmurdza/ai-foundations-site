DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Initial seed for the hh_admins table — used by scripts/db/migrate-admins.mjs only.
# Live auth is the hh_admins table; manage via /admins after seeding.
ADMIN_USERS=burhan:change-me,james:change-me

# Applicant thank-you email (sent on submission). ImprovMX SMTP.
SMTP_HOST=smtp.improvmx.com
SMTP_PORT=587
SMTP_USER=summerschool@aifoundations.school
SMTP_PASS=change-me
SMTP_FROM="AI Foundations <summerschool@aifoundations.school>"

# Shared secret for the Vercel Cron backstop at /api/cron/notify-submissions.
# Vercel injects "Authorization: Bearer $CRON_SECRET" automatically on cron invocations.
CRON_SECRET=change-me
